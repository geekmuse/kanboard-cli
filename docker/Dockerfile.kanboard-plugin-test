# Integration test image — Kanboard with Portfolio Management plugin.
#
# Extends the official Kanboard image and attempts to install the
# kanboard-plugin-portfolio-management plugin.  If the plugin repository
# is unavailable (e.g. CI without internet access, or the repo is private)
# the build succeeds and the integration tests auto-skip via plugin detection.
#
# Usage (from repository root):
#   docker build -f docker/Dockerfile.kanboard-plugin-test -t kanboard-plugin-test .
#   docker compose -f docker-compose.test.yml up -d --wait

FROM kanboard/kanboard:latest

# Install git so we can clone the plugin repository (Alpine-based image).
RUN apk add --no-cache git 2>/dev/null || true

# Attempt to install the Portfolio Management plugin.
# This step is non-fatal: if the repository is unavailable the base
# Kanboard image is used as-is and plugin backend integration tests
# are automatically skipped by the plugin detection probe.
RUN cd /var/www/app/plugins \
    && git clone --depth 1 \
       https://github.com/geekmuse/kanboard-plugin-portfolio-management \
       PortfolioManagement 2>/dev/null \
    && echo "Portfolio Management plugin installed successfully." \
    || echo "Portfolio Management plugin unavailable — plugin backend tests will skip."
